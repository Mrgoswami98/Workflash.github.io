<title>Ankush Kumar — IT Professional CV</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#eef2f7;
  --bg2:#dde6f0;
  --surface:rgba(255,255,255,0.75);
  --surfaceH:rgba(255,255,255,0.92);
  --border:rgba(37,99,235,0.13);
  --borderH:rgba(37,99,235,0.32);
  --text:#1a2540;
  --muted:#6b7a99;
  --accent:#1d4ed8;
  --accentL:rgba(29,78,216,0.12);
  --gold:#2563eb;
  --goldL:rgba(37,99,235,0.12);
  --blue:#3b82f6;
  --blueL:rgba(59,130,246,0.15);
  --green:#0ea5e9;
  --greenL:rgba(14,165,233,0.15);
  --r:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:"Outfit",sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;cursor:none}

/* CURSOR */
#cur,#curR{position:fixed;border-radius:50%;pointer-events:none;z-index:9999;top:0;left:0;transform:translate(-50%,-50%);transition:width .18s,height .18s,opacity .2s}
#cur{width:8px;height:8px;background:var(--accent)}
#curR{width:34px;height:34px;border:1.5px solid var(--accent);opacity:.35}
body.hov #cur{width:44px;height:44px;background:transparent;border:1.5px solid var(--accent);opacity:.5}
body.hov #curR{opacity:0}

/* SCROLL BAR */
#prog{position:fixed;top:0;left:0;height:2px;background:linear-gradient(90deg,#1d4ed8,#3b82f6);z-index:600;width:0%;transition:width .08s}

/* CANVAS */
#bgC{position:fixed;inset:0;z-index:0;opacity:.65}

/* LOADER */
#ldr{position:fixed;inset:0;background:#eef2f7;z-index:2000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;transition:opacity .9s,visibility .9s}
#ldr.out{opacity:0;visibility:hidden}
.ldr-name{font-family:"Syne",sans-serif;font-size:52px;font-weight:800;letter-spacing:-2px;overflow:hidden;color:#1a2540}
.ldr-name span{display:inline-block;transform:translateY(70px);opacity:0;transition:transform .5s ease,opacity .5s ease}
.ldr-sub{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#6b7a99}
.ldr-track{width:220px;height:1px;background:var(--border);position:relative;overflow:hidden}
.ldr-bar{position:absolute;left:-100%;top:0;width:100%;height:100%;background:linear-gradient(90deg,var(--accent),var(--gold))}
.ldr-p{font-family:"JetBrains Mono",monospace;font-size:11px;color:var(--accent)}

/* LAYOUT */
.wrap{max-width:1100px;margin:0 auto;padding:80px 44px;position:relative;z-index:1}

/* ══ HERO ══ */
.hero{
  display:grid;grid-template-columns:1fr 340px;gap:60px;
  align-items:center;min-height:90vh;padding:60px 0 80px;
  position:relative;
}
.hero-left{display:flex;flex-direction:column;gap:0}
.eyebrow{
  display:inline-flex;align-items:center;gap:10px;
  font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;
  color:#1d4ed8;margin-bottom:28px;
  opacity:0;animation:fup .7s .2s ease forwards;
}
.pdot{width:7px;height:7px;border-radius:50%;background:#1d4ed8;animation:pdotAnim 1.4s infinite}
@keyframes pdotAnim{0%,100%{box-shadow:0 0 0 0 var(--accentL)}60%{box-shadow:0 0 0 9px transparent}}

.hname{
  font-family:"Syne",sans-serif;font-size:clamp(48px,6vw,84px);
  font-weight:800;line-height:.92;letter-spacing:-3px;margin-bottom:20px;overflow:hidden;
}
.hname .ln{display:block;transform:translateY(110%);opacity:0}
.hname .ac{color:#1d4ed8}

.hrole{
  font-family:"JetBrains Mono",monospace;font-size:13px;color:var(--muted);
  border-left:2px solid var(--accent);padding-left:16px;margin-bottom:28px;
  min-height:20px;opacity:0;animation:fup .7s .9s ease forwards;
}
.hdesc{
  font-size:15px;font-weight:300;color:var(--muted);line-height:1.75;max-width:480px;
  margin-bottom:36px;opacity:0;animation:fup .7s 1.1s ease forwards;
}
.hbtns{
  display:flex;flex-wrap:wrap;gap:10px;
  opacity:0;animation:fup .7s 1.3s ease forwards;
}
.btn{
  display:inline-flex;align-items:center;gap:8px;padding:13px 26px;
  font-family:"Outfit",sans-serif;font-size:13px;font-weight:500;
  border-radius:var(--r);border:none;cursor:none;text-decoration:none;
  position:relative;overflow:hidden;transition:transform .22s,box-shadow .22s;
}
.btn::after{content:"";position:absolute;inset:0;background:rgba(255,255,255,.07);transform:translateX(-110%) skewX(-12deg);transition:transform .38s}
.btn:hover::after{transform:translateX(110%) skewX(-12deg)}
.bp{background:#1d4ed8;color:#fff}
.bp:hover{transform:translateY(-3px);box-shadow:0 14px 36px rgba(29,78,216,.25)}
.bg{background:var(--surface);color:var(--text);border:1px solid var(--border)}
.bg:hover{transform:translateY(-3px);border-color:var(--borderH);background:var(--surfaceH)}

.scroll-ind{
  display:flex;align-items:center;gap:12px;margin-top:48px;
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;
  opacity:0;animation:fup .7s 1.6s ease forwards;
}
.scroll-line{width:44px;height:1px;background:var(--border);position:relative;overflow:hidden}
.scroll-line::after{content:"";position:absolute;left:-100%;top:0;width:100%;height:100%;background:#1d4ed8;animation:sline 2.2s 2s infinite}
@keyframes sline{0%{left:-100%}100%{left:100%}}

/* ══ PHOTO CARD ══ */
.photo-wrap{
  opacity:0;animation:fleft .9s 1.4s ease forwards;
  display:flex;flex-direction:column;align-items:center;gap:20px;
}
@keyframes fleft{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}

.photo-frame{
  width:260px;height:300px;border-radius:20px;
  position:relative;overflow:hidden;
  border:1px solid var(--border);
}
.photo-frame img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block}
.photo-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(10,25,64,.88) 0%,rgba(10,25,64,.15) 50%,transparent 100%);
}
.photo-name-tag{
  position:absolute;bottom:0;left:0;right:0;padding:20px 18px 16px;
}
.photo-name-tag .pn{
  font-family:"Syne",sans-serif;font-size:18px;font-weight:800;color:#fff;letter-spacing:-.5px;
}
.photo-name-tag .pr{
  font-family:"JetBrains Mono",monospace;font-size:10px;color:var(--accent);letter-spacing:1px;margin-top:2px;
}

/* Animated border on photo */
.photo-border{
  position:absolute;inset:-1px;border-radius:20px;
  border:1.5px solid transparent;
  background:linear-gradient(135deg,#1d4ed8,transparent 40%,#3b82f6 80%,transparent) border-box;
  -webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);
  -webkit-mask-composite:destination-out;mask-composite:exclude;
  animation:spinBorder 5s linear infinite;
}
@keyframes spinBorder{to{transform:rotate(360deg)}}

/* status badges */
.status-row{display:flex;flex-wrap:wrap;gap:6px;justify-content:center}
.sbadge{
  font-family:"JetBrains Mono",monospace;font-size:10px;
  padding:5px 11px;border-radius:20px;border:1px solid var(--border);
  color:var(--muted);background:var(--surface);
  animation:fl var(--d,3s) var(--dl,0s) ease-in-out infinite alternate;
}
@keyframes fl{from{transform:translateY(0)}to{transform:translateY(-5px)}}
.sbadge.hot{border-color:rgba(29,78,216,.35);color:#1d4ed8}

/* ══ STATS ══ */
.stats{
  display:grid;grid-template-columns:repeat(4,1fr);
  border:1px solid var(--border);border-radius:var(--r);overflow:hidden;
  margin-bottom:80px;opacity:0;transform:translateY(20px);transition:all .7s ease;
}
.stats.vis{opacity:1;transform:translateY(0)}
.sc{padding:26px 22px;border-right:1px solid var(--border);position:relative;overflow:hidden;transition:background .3s}
.sc:last-child{border-right:none}
.sc::after{content:"";position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#1d4ed8,#3b82f6);transform:scaleX(0);transform-origin:left;transition:transform .4s}
.sc:hover{background:var(--surface)} .sc:hover::after{transform:scaleX(1)}
.sn{font-family:"Syne",sans-serif;font-size:38px;font-weight:800;line-height:1;
  background:linear-gradient(135deg,#fff,var(--muted));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.sn.cnt{-webkit-text-fill-color:#1d4ed8}
.sl{font-size:11px;color:var(--muted);margin-top:5px;letter-spacing:.5px}

/* ══ SECTION ══ */
.sec{margin-bottom:80px;opacity:0;transform:translateY(24px);transition:opacity .7s,transform .7s}
.sec.vis{opacity:1;transform:translateY(0)}
.sh{display:flex;align-items:center;gap:14px;margin-bottom:34px}
.snum{font-family:"JetBrains Mono",monospace;font-size:11px;color:#1d4ed8;opacity:.7}
.stit{font-family:"Syne",sans-serif;font-size:26px;font-weight:700;letter-spacing:-1px}
.sline{flex:1;height:1px;background:rgba(37,99,235,.15)}

/* ══ EXP ══ */
.estack{display:flex;flex-direction:column;gap:10px}
.ecard{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r);
  padding:22px 26px;position:relative;overflow:hidden;
  transition:border-color .3s,transform .3s,background .3s;cursor:default;
}
.ecard::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(to bottom,#1d4ed8,#3b82f6);transform:scaleY(0);transform-origin:top;transition:transform .35s}
.ecard:hover{border-color:var(--borderH);background:var(--surfaceH);transform:translateX(5px)}
.ecard:hover::before{transform:scaleY(1)}
.etop{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:8px;flex-wrap:wrap}
.eco{font-family:"Syne",sans-serif;font-size:16px;font-weight:700}
.erl{font-size:12px;color:#1d4ed8;font-weight:500;margin-bottom:2px}
.edt{font-family:"JetBrains Mono",monospace;font-size:10px;color:var(--muted);padding:3px 9px;border:1px solid var(--border);border-radius:20px;white-space:nowrap;flex-shrink:0}
.ecur{font-family:"JetBrains Mono",monospace;font-size:10px;padding:3px 8px;border-radius:20px;background:rgba(29,78,216,.1);color:#1d4ed8;border:1px solid rgba(29,78,216,.3);animation:pdotAnim 1.4s infinite;display:inline-block;margin-bottom:4px}
.edesc{font-size:13px;color:var(--muted);line-height:1.7;margin-top:6px}
.etags{display:flex;flex-wrap:wrap;gap:5px;margin-top:10px}
.etag{font-family:"JetBrains Mono",monospace;font-size:10px;padding:3px 8px;border-radius:3px;background:rgba(255,255,255,.03);border:1px solid var(--border);color:var(--muted);transition:all .2s}
.etag:hover{background:rgba(29,78,216,.08);border-color:#1d4ed8;color:#1d4ed8}

/* ══ SKILLS ══ */
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.sblk{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:20px 22px}
.sblt{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#1d4ed8;margin-bottom:16px}
.skb{margin-bottom:13px}
.skt{display:flex;justify-content:space-between;font-size:12px;font-weight:500;margin-bottom:5px}
.skp{color:var(--muted);font-size:11px}
.sktr{height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.skf{height:100%;border-radius:2px;width:0%;transition:width 1.4s cubic-bezier(.22,1,.36,1)}
.fa{background:linear-gradient(90deg,#1d4ed8,#3b82f6)}
.fg{background:linear-gradient(90deg,#0ea5e9,#38bdf8)}
.fb{background:linear-gradient(90deg,#6366f1,#a5b4fc)}
.fv{background:linear-gradient(90deg,#0284c7,#38bdf8)}

.tcloud{display:flex;flex-wrap:wrap;gap:7px;margin-top:4px}
.tchip{font-family:"JetBrains Mono",monospace;font-size:11px;padding:6px 13px;border-radius:var(--r);background:var(--surface);border:1px solid var(--border);color:var(--muted);transition:all .22s;cursor:default}
.tchip:hover{background:rgba(29,78,216,.08);border-color:#1d4ed8;color:#1d4ed8;transform:translateY(-4px);box-shadow:0 8px 24px rgba(29,78,216,.15)}
.tchip.hot{border-color:rgba(29,78,216,.3);color:#1d4ed8}

/* ══ EDU TIMELINE ══ */
.etl{position:relative;padding-left:30px}
.etl::before{content:"";position:absolute;left:5px;top:8px;bottom:8px;width:1px;background:rgba(37,99,235,.2)}
.ei{position:relative;margin-bottom:16px;padding:16px 20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);transition:all .22s}
.ei:hover{border-color:var(--borderH);background:var(--surfaceH);transform:translateX(4px)}
.ei::before{content:"";position:absolute;left:-29px;top:22px;width:10px;height:10px;border-radius:50%;background:#eef2f7;border:2px solid #1d4ed8;transition:background .2s}
.ei:hover::before{background:#1d4ed8}
.eiy{font-family:"JetBrains Mono",monospace;font-size:10px;color:#1d4ed8;margin-bottom:3px}
.ein{font-size:14px;font-weight:600}
.eii{font-size:12px;color:var(--muted);margin-top:2px}

/* ══ PERSONAL ══ */
.pgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.pr{display:flex;align-items:center;gap:12px;padding:13px 16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);transition:all .2s}
.pr:hover{border-color:var(--borderH);background:var(--surfaceH)}
.pk{font-family:"JetBrains Mono",monospace;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);min-width:78px}
.pv{font-size:13px;font-weight:500}

/* ══ DECLARATION ══ */
.decl{border-top:1px solid rgba(37,99,235,.15);padding-top:44px;margin-top:80px;display:flex;justify-content:space-between;align-items:flex-end;opacity:0;transform:translateY(20px);transition:all .7s}
.decl.vis{opacity:1;transform:translateY(0)}
.dtxt{font-family:"JetBrains Mono",monospace;font-size:11px;color:#6b7a99;line-height:1.8;max-width:400px}
.sig{font-family:"Syne",sans-serif;font-size:30px;font-weight:800;letter-spacing:-1px;background:linear-gradient(135deg,#1a2540,#1d4ed8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;border-bottom:2px solid #1d4ed8;padding-bottom:4px}
.sigs{font-family:"JetBrains Mono",monospace;font-size:10px;color:#6b7a99;margin-top:5px;text-align:right}

/* ══ FLOAT NAV ══ */
.fnav{position:fixed;right:26px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:10px;z-index:100}
.fd{width:6px;height:6px;border-radius:50%;background:var(--border);cursor:none;transition:all .25s;position:relative}
.fd:hover,.fd.act{background:#1d4ed8;transform:scale(1.7)}
.fd::after{content:attr(data-l);position:absolute;right:16px;top:50%;transform:translateY(-50%);font-family:"JetBrains Mono",monospace;font-size:10px;color:var(--text);white-space:nowrap;opacity:0;transition:opacity .2s;pointer-events:none;background:#fff;padding:3px 8px;border-radius:3px;border:1px solid rgba(37,99,235,.2)}
.fd:hover::after{opacity:1}

/* UTILS */
@keyframes fup{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* PRINT */
@media print{
  body{background:#fff;color:#000;cursor:auto}
  #cur,#curR,#ldr,.fnav,#prog,#bgC,.scroll-ind{display:none!important}
  .sec,.stats,.decl{opacity:1!important;transform:none!important}
  .hname .ln,.eyebrow,.hrole,.hdesc,.hbtns,.photo-wrap{opacity:1!important;transform:none!important;animation:none!important}
  .photo-border{display:none}
}
@media(max-width:768px){
  .hero{grid-template-columns:1fr;gap:40px}
  .photo-wrap{order:-1;align-items:flex-start}
  .photo-frame{width:180px;height:210px}
  .stats,.sgrid,.pgrid{grid-template-columns:1fr 1fr}
  .fnav{display:none}
  .wrap{padding:48px 20px}
  .hname{font-size:44px}
}
@media(max-width:480px){
  .stats,.sgrid,.pgrid{grid-template-columns:1fr}
  .etop{flex-direction:column}
}
</style>
</head>
