<script>
/* CURSOR */
const cur=document.getElementById("cur"),curR=document.getElementById("curR");
let mx=0,my=0,rx=0,ry=0;
document.addEventListener("mousemove",e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+"px";cur.style.top=my+"px"});
(function aR(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;curR.style.left=rx+"px";curR.style.top=ry+"px";requestAnimationFrame(aR)})();
document.querySelectorAll("a,button,.ecard,.tchip,.ei,.pr,.fd,.sc").forEach(el=>{
  el.addEventListener("mouseenter",()=>document.body.classList.add("hov"));
  el.addEventListener("mouseleave",()=>document.body.classList.remove("hov"));
});

/* CANVAS PARTICLES */
const cv=document.getElementById("bgC"),cx=cv.getContext("2d");
let W,H,pts=[];
function rs(){W=cv.width=window.innerWidth;H=cv.height=window.innerHeight}
rs();window.addEventListener("resize",rs);
class Pt{constructor(){this.reset()}reset(){this.x=Math.random()*W;this.y=Math.random()*H;this.r=Math.random()*.7+.15;this.vx=(Math.random()-.5)*.12;this.vy=(Math.random()-.5)*.12;this.a=Math.random()*.35+.05}
  update(){this.x+=this.vx;this.y+=this.vy;if(this.x<0||this.x>W||this.y<0||this.y>H)this.reset()}
  draw(){cx.beginPath();cx.arc(this.x,this.y,this.r,0,Math.PI*2);cx.fillStyle=`rgba(37,99,235,${this.a})`;cx.fill()}}
for(let i=0;i<100;i++)pts.push(new Pt());
function aCV(){cx.clearRect(0,0,W,H);
  for(let i=0;i<pts.length;i++){for(let j=i+1;j<pts.length;j++){const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<110){cx.beginPath();cx.moveTo(pts[i].x,pts[i].y);cx.lineTo(pts[j].x,pts[j].y);cx.strokeStyle=`rgba(37,99,235,${(1-d/110)*.09})`;cx.lineWidth=.4;cx.stroke()}}}
  pts.forEach(p=>{p.update();p.draw()});requestAnimationFrame(aCV)}
aCV();

/* LOADER */
const ldrB=document.getElementById("ldrB"),ldrP=document.getElementById("ldrP");
document.querySelectorAll(".ldr-name span").forEach((s,i)=>setTimeout(()=>{s.style.transform="translateY(0)";s.style.opacity="1"},i*55));
let pv=0;
const lt=setInterval(()=>{pv=Math.min(pv+(Math.random()*4+1.5),100);ldrB.style.left=-(100-pv)+"%";ldrP.textContent=Math.floor(pv)+"%";
  if(pv>=100){clearInterval(lt);setTimeout(()=>{document.getElementById("ldr").classList.add("out");startHero()},300)}},28);

/* HERO */
function startHero(){
  ["ln1","ln2"].forEach((id,i)=>{const el=document.getElementById(id);el.style.transition=`transform .8s ${i*.18}s cubic-bezier(.22,1,.36,1),opacity .8s ${i*.18}s ease`;el.style.transform="translateY(0)";el.style.opacity="1"});
  const roles=["Senior Data Analyst","Chief IT Solutioner","AppSheet Specialist","Dashboard Architect","MIS Executive & CTO"];
  let ri=0,ci=0,del=false,tw=document.getElementById("tw");
  function typ(){const c=roles[ri];if(!del){tw.textContent=c.slice(0,++ci);if(ci===c.length){del=true;setTimeout(typ,1900);return}}
    else{tw.textContent=c.slice(0,--ci);if(ci===0){del=false;ri=(ri+1)%roles.length}}
    setTimeout(typ,del?38:75)}
  setTimeout(typ,700);
}

/* SCROLL PROGRESS */
window.addEventListener("scroll",()=>{const e=document.documentElement;document.getElementById("prog").style.width=(e.scrollTop/(e.scrollHeight-e.clientHeight)*100)+"%"});

/* INTERSECTION */
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{
  if(!e.isIntersecting)return;
  e.target.classList.add("vis");
  e.target.querySelectorAll(".skf[data-w]").forEach(b=>setTimeout(()=>{b.style.width=b.dataset.w+"%"},180));
  e.target.querySelectorAll("[data-to]").forEach(el=>{let v=0,to=+el.dataset.to;el.classList.add("cnt");
    const t=setInterval(()=>{v=Math.min(v+(to/40),to);el.textContent=Math.floor(v)+(to===100?"%":"+");if(v>=to){el.classList.remove("cnt");clearInterval(t)}},28)});
  obs.unobserve(e.target);
})},{threshold:0.07});
document.querySelectorAll(".sec,.stats,.decl").forEach(s=>obs.observe(s));

/* FLOAT NAV */
const secIds=["hero","stats","exp","skills","edu","personal","dashboard","crm","techedu"],fds=document.querySelectorAll(".fd");
fds.forEach(d=>d.addEventListener("click",()=>{const el=document.getElementById(d.dataset.s);if(el)el.scrollIntoView({behavior:"smooth"})}));
window.addEventListener("scroll",()=>{let c=0;secIds.forEach((id,i)=>{const el=document.getElementById(id);if(el&&window.scrollY>=el.offsetTop-280)c=i});fds.forEach((d,i)=>d.classList.toggle("act",i===c))});


/* ANIMATE DASHBOARD CHARTS ON SCROLL */
const chartObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    // KPI counters
    const kpiData = [[kpi1,100],[kpi2,30],[kpi3,80],[kpi4,15]];
    kpiData.forEach(([id, to]) => {
      const el = document.getElementById(id);
      if (!el) return;
      let v = 0;
      const t = setInterval(() => {
        v = Math.min(v + (to / 30), to);
        el.textContent = Math.floor(v) + '+';
        if (v >= to) clearInterval(t);
      }, 35);
    });
    // Bar chart bars
    document.querySelectorAll('.bc-bar[data-val]').forEach(b => {
      setTimeout(() => { b.style.width = b.style.getPropertyValue('--w'); }, 200);
    });
    // Timeline bars
    document.querySelectorAll('.tb-fill').forEach((b, i) => {
      setTimeout(() => { b.style.width = b.style.width || getComputedStyle(b).width; }, i * 80);
    });
    // Donut segments
    document.querySelectorAll('.donut-seg').forEach(seg => {
      const da = seg.style.getPropertyValue('--da');
      const off = seg.style.getPropertyValue('--offset') || '0';
      setTimeout(() => {
        seg.style.strokeDasharray = da + ' ' + (377 - da);
        seg.style.strokeDashoffset = off;
      }, 300);
    });
    chartObs.disconnect();
  });
}, { threshold: 0.05 });
const dashSec = document.getElementById('dashboard');
if (dashSec) chartObs.observe(dashSec);

/* DATE */
document.getElementById("tod").textContent=new Date().toLocaleDateString("en-IN",{day:"2-digit",month:"long",year:"numeric"});
</script>

